rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Dynamic collection pattern: doses-{uid}
    // Uses recursive wildcard to match any collection, then validates name
    match /{collectionName}/{docId} {
      // Allow access to doses-{uid} collections where uid matches auth user
      allow read, write: if isAuthenticated()
        && collectionName.matches('doses-.*')
        && collectionName == 'doses-' + request.auth.uid;
    }

    // Settings collection: per-user settings document keyed by UID
    match /settings/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // User profiles collection (for premium features)
    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Taper plans collection (premium feature)
    match /{collectionName}/{docId} {
      allow read, write: if isAuthenticated()
        && collectionName.matches('taper-plans-.*')
        && collectionName == 'taper-plans-' + request.auth.uid;
    }

    // Goals collection (premium feature)
    match /{collectionName}/{docId} {
      allow read, write: if isAuthenticated()
        && collectionName.matches('goals-.*')
        && collectionName == 'goals-' + request.auth.uid;
    }
  }
}
